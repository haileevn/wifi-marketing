# Port server portal (Nginx/CloudPanel proxy vào port này)
PORT=20140

# Đường dẫn file database SQLite
DB_PATH=./data/wifi.db

# Tài khoản đăng nhập trang quản trị /admin (Basic Auth)
ADMIN_USER=admin
ADMIN_PASS=doi-mat-khau-nay-ngay

# Khoá mã hoá SSH password trong SQLite (≥16 ký tự, đổi trên mỗi môi trường)
# Thiếu key = password lưu plaintext (chỉ chấp nhận khi phát triển local)
SECRETS_KEY=doi-secrets-key-nay-ngay

# FAS key mặc định khi tạo quán mới (mỗi quán có thể đặt key riêng)
DEFAULT_FASKEY=h2t-wifi-secret-2026

# After enroll thành công: tự revoke token cài đặt (1=bật, 0=giữ link tái dùng)
ENROLL_ONE_SHOT=1

# ==== Zalo ZNS (bỏ trống = chế độ DRY-RUN, chỉ log không gửi thật) ====
ZALO_APP_ID=
ZALO_APP_SECRET=
ZNS_TEMPLATE_ID=
# Khách ghé lần thứ mấy thì gửi ưu đãi
ZNS_VISIT_MILESTONE=3
ZNS_VOUCHER_CODE=THANQUEN10

# ==== Tailscale (enroll router qua mesh VPN) ====
# https://login.tailscale.com/admin/settings/keys
# Khuyến nghị: Reusable=Yes, Ephemeral=No, Tags=tag:router
# Rotate key ngay nếu nghi ngờ lộ; ACL chỉ cho phép VPS SSH → tag:router
TAILSCALE_AUTHKEY=

# ==== Tailscale Admin API (áp ACL) ====
# https://login.tailscale.com/admin/settings/keys → Generate API access token
TAILSCALE_API_KEY=
TAILSCALE_TAILNET=
