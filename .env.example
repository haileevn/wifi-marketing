# Port server portal (Nginx/CloudPanel proxy vào port này)
PORT=20140

# Đường dẫn file database SQLite
DB_PATH=./data/wifi.db

# Tài khoản đăng nhập trang quản trị /admin (Basic Auth)
ADMIN_USER=admin
ADMIN_PASS=doi-mat-khau-nay-ngay

# FAS key mặc định khi tạo quán mới (mỗi quán có thể đặt key riêng)
DEFAULT_FASKEY=h2t-wifi-secret-2026

# ==== Zalo ZNS (bỏ trống = chế độ DRY-RUN, chỉ log không gửi thật) ====
ZALO_APP_ID=
ZALO_APP_SECRET=
ZNS_TEMPLATE_ID=
# Khách ghé lần thứ mấy thì gửi ưu đãi
ZNS_VISIT_MILESTONE=3
ZNS_VOUCHER_CODE=THANQUEN10

# ==== Tailscale (để gói cài đặt tự động enroll router qua mesh VPN) ====
# Lấy tại: https://login.tailscale.com/admin/settings/keys
# Nên tạo key: Reusable=Yes, Ephemeral=No, gắn Tag (vd tag:router) để dễ quản lý ACL
TAILSCALE_AUTHKEY=
