<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Quản lý Menu — <%= location.display_name %></title>
<style>
:root{--ink:#1a202c;--paper:#f7f8fa;--accent:#3B82F6;--line:#e2e8f0}
*{margin:0;box-sizing:border-box}
body{font-family:-apple-system,"Segoe UI",Roboto,sans-serif;background:var(--paper);color:var(--ink);padding:24px 20px 60px}
.wrap{max-width:800px;margin:0 auto}
.head{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.back{width:34px;height:34px;border-radius:9px;background:#fff;border:1px solid var(--line);display:flex;align-items:center;justify-content:center;text-decoration:none;color:var(--ink)}
h1{font-size:20px;font-weight:800}
.sub{color:#64748b;font-size:13px}
form.add{background:#fff;border:1px solid var(--line);border-radius:14px;padding:16px;margin-bottom:20px;display:grid;gap:8px;grid-template-columns:repeat(auto-fit,minmax(140px,1fr))}
form.add input,form.add select,form.add textarea{padding:8px 10px;border:1px solid var(--line);border-radius:8px;font-size:13px}
form.add textarea{grid-column:1/-1;min-height:50px}
.btn{padding:9px 16px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:4px}
.btn-red{background:#EF4444}
.btn-sm{padding:5px 10px;font-size:12px;border-radius:6px}
.item{display:flex;align-items:center;gap:12px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:10px 14px;margin-bottom:8px}
.item img{width:48px;height:48px;border-radius:8px;object-fit:cover;background:#eee}
.item-info{flex:1}
.item-info b{font-size:14px}
.item-info span{font-size:12px;color:#64748b;display:block}
.item-price{font-weight:800;color:var(--accent);font-size:14px}
.cat-title{font-size:13px;font-weight:700;color:#64748b;text-transform:uppercase;margin:18px 0 8px}
.unavailable{opacity:.5}
.toggle-link{background:#f1f5f9;color:#334155}
.view-link{background:#7C3AED}
</style>
</head>
<body>
<div class="wrap">
  <div class="head">
    <a class="back" href="/admin">←</a>
    <div><h1>Menu — <%= location.display_name %></h1><p class="sub"><%= items.length %> món</p></div>
    <a class="btn view-link" style="margin-left:auto" href="/menu/<%= location.id %>" target="_blank">👁️ Xem menu công khai</a>
  </div>

  <form method="POST" action="/admin/menu/<%= location.id %>/enable" style="margin-bottom:16px;display:flex;align-items:center;gap:10px;background:#fff;border:1px solid var(--line);border-radius:12px;padding:12px 16px">
    <label style="font-size:13px;font-weight:600;flex:1">Hiện nút "Xem Menu" trên trang sau khi khách kết nối WiFi</label>
    <input type="hidden" name="enabled" value="<%= location.menu_enabled ? '0' : '1' %>">
    <button class="btn btn-sm" style="background:<%= location.menu_enabled ? '#EF4444' : '#10B981' %>" type="submit">
      <%= location.menu_enabled ? 'Đang BẬT — Tắt đi' : 'Đang TẮT — Bật lên' %>
    </button>
  </form>

  <form class="add" method="POST" action="/admin/menu/<%= location.id %>">
    <input name="name" placeholder="Tên món (vd: Cơm tấm sườn bì chả)" required>
    <input name="category" placeholder="Danh mục (vd: Món chính)" value="Món chính">
    <input name="price" type="number" placeholder="Giá (vd: 45000)">
    <textarea name="description" placeholder="Mô tả ngắn (không bắt buộc)"></textarea>
    <input type="hidden" name="image_data" id="imgData">
    <input type="file" accept="image/*" onchange="toBase64(this)">
    <button class="btn" type="submit">+ Thêm món</button>
  </form>

  <% const cats = [...new Set(items.map(i=>i.category))]; %>
  <% cats.forEach(cat => { %>
    <div class="cat-title"><%= cat %></div>
    <% items.filter(i=>i.category===cat).forEach(item => { %>
      <div class="item <%= item.available?'':'unavailable' %>">
        <% if (item.image_data) { %><img src="<%- item.image_data %>"><% } else { %><div style="width:48px;height:48px;border-radius:8px;background:#f1f5f9"></div><% } %>
        <div class="item-info">
          <b><%= item.name %></b>
          <span><%= item.description||'' %></span>
        </div>
        <div class="item-price"><%= item.price?item.price.toLocaleString('vi-VN')+'đ':'' %></div>
        <form method="POST" action="/admin/menu/<%= location.id %>/<%= item.id %>/toggle">
          <button class="btn btn-sm toggle-link" type="submit"><%= item.available?'Ẩn':'Hiện' %></button>
        </form>
        <form method="POST" action="/admin/menu/<%= location.id %>/<%= item.id %>/delete" onsubmit="return confirm('Xoá món này?')">
          <button class="btn btn-sm btn-red" type="submit">Xoá</button>
        </form>
      </div>
    <% }) %>
  <% }) %>
</div>
<script>
function toBase64(input) {
  if (!input.files[0]) return;
  if (input.files[0].size > 800*1024) { alert('Ảnh quá lớn, dùng ảnh dưới 800KB'); return; }
  const reader = new FileReader();
  reader.onload = e => { document.getElementById('imgData').value = e.target.result; };
  reader.readAsDataURL(input.files[0]);
}
</script>
</body>
</html>
