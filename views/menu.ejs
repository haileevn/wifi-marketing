<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Menu — <%= location.display_name %></title>
<style>
:root{--accent:<%- location.accent_color||'#B4452C' %>;--bg:<%- location.bg_color||'#FFF6EC' %>;
      --card:<%- location.card_color||'#FFFFFF' %>;--ink:<%- location.text_color||'#241610' %>}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,"Segoe UI",Roboto,sans-serif;background:var(--bg);color:var(--ink)}
header{padding:24px 20px 16px;text-align:center;position:sticky;top:0;background:var(--bg);z-index:10;border-bottom:1px solid rgba(0,0,0,.06)}
header h1{font-size:22px;font-weight:800}
header p{font-size:13px;color:#8A7A66;margin-top:4px}
.cat-nav{display:flex;gap:8px;overflow-x:auto;padding:12px 16px;background:var(--bg);position:sticky;top:78px;z-index:9;-webkit-overflow-scrolling:touch}
.cat-nav a{flex-shrink:0;padding:7px 14px;border-radius:20px;background:var(--card);border:1.5px solid rgba(0,0,0,.1);font-size:13px;font-weight:600;color:var(--ink);text-decoration:none;white-space:nowrap}
main{padding:8px 16px 40px;max-width:600px;margin:0 auto}
.category{margin-top:22px}
.category h2{font-size:17px;font-weight:800;margin-bottom:10px;color:var(--accent)}
.item{display:flex;gap:12px;background:var(--card);border-radius:14px;padding:12px;margin-bottom:10px;border:1px solid rgba(0,0,0,.06)}
.item img{width:64px;height:64px;border-radius:10px;object-fit:cover;flex-shrink:0;background:#eee}
.item-info{flex:1;min-width:0}
.item-info h3{font-size:15px;font-weight:700}
.item-info p{font-size:12px;color:#8A7A66;margin-top:2px;line-height:1.4}
.item-price{font-size:15px;font-weight:800;color:var(--accent);white-space:nowrap;margin-left:auto;align-self:center}
.unavailable{opacity:.4}
.badge-out{font-size:10px;background:#EF4444;color:#fff;padding:2px 6px;border-radius:6px;margin-left:6px;vertical-align:middle}
.empty{text-align:center;padding:60px 20px;color:#8A7A66}
</style>
</head>
<body>
<header>
  <h1><%= location.display_name %></h1>
  <p>Thực đơn</p>
</header>

<% const cats = Object.keys(byCategory); %>
<% if (cats.length) { %>
<nav class="cat-nav">
  <% cats.forEach(c => { %><a href="#cat-<%= c.replace(/\s+/g,'-') %>"><%= c %></a><% }) %>
</nav>
<% } %>

<main>
<% if (!cats.length) { %>
  <div class="empty">Quán chưa cập nhật menu.<br>Vui lòng hỏi trực tiếp nhân viên nhé!</div>
<% } %>
<% cats.forEach(cat => { %>
  <div class="category" id="cat-<%= cat.replace(/\s+/g,'-') %>">
    <h2><%= cat %></h2>
    <% byCategory[cat].forEach(item => { %>
      <div class="item <%= item.available ? '' : 'unavailable' %>">
        <% if (item.image_data) { %><img src="<%- item.image_data %>" alt="<%= item.name %>"><% } %>
        <div class="item-info">
          <h3><%= item.name %><% if (!item.available) { %><span class="badge-out">Hết món</span><% } %></h3>
          <% if (item.description) { %><p><%= item.description %></p><% } %>
        </div>
        <div class="item-price"><%= item.price ? item.price.toLocaleString('vi-VN')+'đ' : '' %></div>
      </div>
    <% }) %>
  </div>
<% }) %>
</main>
</body>
</html>
