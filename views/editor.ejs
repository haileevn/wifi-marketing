<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Chỉnh sửa Portal — <%= location.display_name %></title>
<style>
/* ─── Editor shell ─── */
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;font-family:-apple-system,"Segoe UI",Roboto,sans-serif;background:#EDEEF2;color:#1a202c;font-size:14px}
a{color:inherit;text-decoration:none}

/* ─── Layout ─── */
.shell{display:flex;height:100vh}
.sidebar{width:360px;min-width:360px;background:#fff;display:flex;flex-direction:column;border-right:1px solid #e2e8f0;overflow:hidden}
.preview-panel{flex:1;display:flex;flex-direction:column;overflow:hidden}

/* ─── Sidebar header ─── */
.sb-head{padding:16px 20px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:10px}
.sb-head .back{width:32px;height:32px;border-radius:8px;background:#f7fafc;display:flex;align-items:center;justify-content:center;cursor:pointer;border:1px solid #e2e8f0;flex-shrink:0}
.sb-head .back:hover{background:#edf2f7}
.sb-head h2{font-size:15px;font-weight:700;line-height:1.2;flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.sb-head .save-btn{padding:8px 16px;background:#3B82F6;color:#fff;border:none;border-radius:8px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap}
.sb-head .save-btn:hover{background:#2563EB}

/* ─── Saved toast ─── */
.toast{position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#10B981;color:#fff;padding:10px 20px;border-radius:10px;font-weight:600;font-size:13px;z-index:999;animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0;transform:translateX(-50%) translateY(-10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}

/* ─── Tab nav ─── */
.tab-nav{display:flex;border-bottom:1px solid #e2e8f0;background:#f8fafc;padding:0 8px}
.tab-nav button{flex:1;padding:10px 4px;border:none;background:none;font-size:12px;font-weight:600;color:#64748b;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.tab-nav button.active{color:#3B82F6;border-bottom-color:#3B82F6}
.tab-nav button:hover:not(.active){color:#334155;background:#edf2f7}

/* ─── Panels ─── */
.panels{flex:1;overflow-y:auto}
.panel{display:none;padding:20px}
.panel.active{display:block}

/* ─── Form elements ─── */
.section-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#94a3b8;margin:16px 0 8px}
.section-title:first-child{margin-top:0}
.field{margin-bottom:12px}
.field label{display:block;font-size:12px;font-weight:600;color:#475569;margin-bottom:4px}
.field input[type=text],.field input[type=url],.field textarea{width:100%;padding:8px 10px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;color:#1a202c;outline:none;transition:border .15s;background:#fff}
.field input:focus,.field textarea:focus{border-color:#3B82F6;box-shadow:0 0 0 3px rgba(59,130,246,.15)}
.field textarea{resize:vertical;min-height:72px;font-family:monospace;font-size:12px}
.field small{display:block;color:#94a3b8;font-size:11px;margin-top:3px}

/* ─── Color picker ─── */
.color-row{display:flex;align-items:center;gap:8px}
.color-swatch{width:36px;height:36px;border-radius:8px;border:2px solid rgba(0,0,0,.1);cursor:pointer;flex-shrink:0;position:relative;overflow:hidden}
.color-swatch input[type=color]{position:absolute;inset:-4px;opacity:0;cursor:pointer;width:calc(100%+8px);height:calc(100%+8px)}
.color-label{flex:1;font-size:13px;color:#334155}
.color-hex{font-size:12px;color:#64748b;font-family:monospace;width:70px;padding:4px 6px;border:1px solid #e2e8f0;border-radius:6px;text-align:center}

/* ─── Toggle ─── */
.toggle-row{display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f1f5f9}
.toggle-row:last-child{border-bottom:none}
.toggle-label{font-size:13px;color:#334155}
.toggle{position:relative;display:inline-block;width:40px;height:22px}
.toggle input{opacity:0;width:0;height:0}
.slider{position:absolute;inset:0;background:#cbd5e1;border-radius:11px;cursor:pointer;transition:.2s}
.slider:before{content:"";position:absolute;height:16px;width:16px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:.2s}
.toggle input:checked+.slider{background:#3B82F6}
.toggle input:checked+.slider:before{transform:translateX(18px)}

/* ─── Logo upload ─── */
.logo-drop{border:2px dashed #e2e8f0;border-radius:12px;padding:20px;text-align:center;cursor:pointer;transition:.2s;background:#f8fafc}
.logo-drop:hover,.logo-drop.over{border-color:#3B82F6;background:#eff6ff}
.logo-drop .icon{font-size:28px;margin-bottom:6px}
.logo-drop p{font-size:12px;color:#64748b}
.logo-preview{position:relative;text-align:center;padding:12px;background:#f8fafc;border-radius:12px;border:1px solid #e2e8f0}
.logo-preview img{max-height:80px;max-width:200px;border-radius:6px;object-fit:contain}
.logo-preview .remove-logo{position:absolute;top:4px;right:4px;width:22px;height:22px;background:#EF4444;color:#fff;border-radius:50%;border:none;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center}

/* ─── Template cards ─── */
.template-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
.tpl-card{border:2px solid #e2e8f0;border-radius:12px;padding:10px;cursor:pointer;transition:.15s;background:#fff}
.tpl-card:hover{border-color:#93c5fd}
.tpl-card.selected{border-color:#3B82F6;box-shadow:0 0 0 3px rgba(59,130,246,.2)}
.tpl-preview{height:48px;border-radius:8px;margin-bottom:8px;display:flex;align-items:center;justify-content:center;font-size:20px}
.tpl-name{font-size:12px;font-weight:700;color:#1a202c}
.tpl-desc{font-size:11px;color:#64748b;margin-top:2px}

/* ─── Preview panel header ─── */
.pv-head{padding:12px 16px;background:#fff;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;gap:12px}
.pv-head h3{font-size:13px;font-weight:600;color:#64748b;flex:1}
.device-btns{display:flex;gap:4px}
.device-btn{padding:6px 12px;border:1px solid #e2e8f0;border-radius:8px;background:#f8fafc;cursor:pointer;font-size:12px;color:#64748b;display:flex;align-items:center;gap:4px}
.device-btn.active{background:#3B82F6;color:#fff;border-color:#3B82F6}
.pv-frame-wrap{flex:1;overflow:auto;display:flex;align-items:flex-start;justify-content:center;padding:24px;background:#EDEEF2}
.pv-frame-wrap.mobile-mode{align-items:flex-start}
.phone-shell{background:#1a202c;border-radius:40px;padding:12px;box-shadow:0 20px 60px rgba(0,0,0,.35);width:375px;flex-shrink:0}
.phone-notch{height:28px;background:#0a0a0a;border-radius:20px 20px 0 0;margin-bottom:2px;display:flex;align-items:center;justify-content:center}
.phone-notch::after{content:"";width:60px;height:8px;background:#2d2d2d;border-radius:4px}
.phone-screen{border-radius:0 0 8px 8px;overflow:hidden;height:680px}
.phone-screen iframe{width:100%;height:100%;border:none;display:block}
.desktop-frame{width:100%;max-width:960px;height:100%;border:none;background:#fff;border-radius:12px;box-shadow:0 4px 24px rgba(0,0,0,.1)}
</style>
</head>
<body>
<% if (saved) { %><div class="toast" id="toast">✓ Đã lưu thay đổi</div><% } %>

<div class="shell">
<!-- ════════ SIDEBAR ════════ -->
<div class="sidebar">
  <div class="sb-head">
    <a class="back" href="/admin" title="Về Admin">←</a>
    <h2><%= location.display_name %></h2>
    <button class="save-btn" onclick="document.getElementById('designForm').requestSubmit()">Lưu</button>
  </div>

  <div class="tab-nav">
    <button class="active" onclick="switchTab('tpl',this)">🎨 Theme</button>
    <button onclick="switchTab('brand',this)">🖼️ Logo</button>
    <button onclick="switchTab('content',this)">✏️ Nội dung</button>
    <button onclick="switchTab('colors',this)">🎨 Màu</button>
    <button onclick="switchTab('adv',this)">⚙️ Nâng cao</button>
  </div>

  <div class="panels">
  <form id="designForm" method="POST" action="/admin/editor/<%= location.id %>">

    <!-- Tab: Template -->
    <div class="panel active" id="panel-tpl">
      <p class="section-title">Chọn giao diện có sẵn</p>
      <div class="template-grid" id="tplGrid">
        <!-- generated by JS -->
      </div>
      <input type="hidden" name="template_id" id="f_template_id" value="<%= location.template_id||'classic' %>">
    </div>

    <!-- Tab: Branding -->
    <div class="panel" id="panel-brand">
      <p class="section-title">Logo quán</p>
      <div id="logoDrop" class="logo-drop" onclick="document.getElementById('logoFile').click()">
        <div class="icon">📷</div>
        <p>Bấm để chọn ảnh logo<br><small>PNG/JPG/SVG • Khuyên dùng < 200KB</small></p>
      </div>
      <div id="logoPreviewWrap" style="display:none">
        <div class="logo-preview">
          <img id="logoPreviewImg" src="" alt="Logo">
          <button type="button" class="remove-logo" onclick="removeLogo()">×</button>
        </div>
      </div>
      <input type="file" id="logoFile" accept="image/*" style="display:none">
      <input type="hidden" name="logo_data" id="f_logo_data" value="<%- location.logo_data||'' %>">

      <p class="section-title" style="margin-top:16px">Thông tin quán</p>
      <div class="field">
        <label>Tên quán hiển thị trên portal</label>
        <input type="text" name="display_name" id="f_display_name" value="<%= location.display_name %>" oninput="refresh()">
      </div>
    </div>

    <!-- Tab: Content -->
    <div class="panel" id="panel-content">
      <div class="field">
        <label>Tiêu đề phụ (dưới tên quán)</label>
        <input type="text" name="headline" id="f_headline" value="<%= location.headline||'WiFi Miễn Phí' %>" oninput="refresh()">
      </div>
      <div class="field">
        <label>Khuyến mãi / Lời chào</label>
        <textarea name="promo_text" id="f_promo_text" oninput="refresh()"><%= location.promo_text||'' %></textarea>
        <small>Hiển thị trong khung dashed. Để trống nếu không cần.</small>
      </div>
      <div class="field">
        <label>Nút kết nối</label>
        <input type="text" name="btn_text" id="f_btn_text" value="<%= location.btn_text||'Kết nối Internet' %>" oninput="refresh()">
      </div>

      <p class="section-title">Trường nhập tên</p>
      <div class="toggle-row">
        <span class="toggle-label">Hiển thị trường tên</span>
        <label class="toggle">
          <input type="checkbox" name="show_name" id="f_show_name" value="1" <%=location.show_name?'checked':''%> onchange="refresh()">
          <span class="slider"></span>
        </label>
      </div>
      <div class="toggle-row" id="requireNameRow" style="<%=location.show_name?'':'opacity:.4;pointer-events:none'%>">
        <span class="toggle-label">Bắt buộc nhập tên</span>
        <label class="toggle">
          <input type="checkbox" name="require_name" id="f_require_name" value="1" <%=location.require_name?'checked':''%> onchange="refresh()">
          <span class="slider"></span>
        </label>
      </div>

      <p class="section-title" style="margin-top:16px">Sau khi kết nối WiFi</p>
      <div class="field">
        <label>URL chuyển hướng (ưu tiên cao nhất)</label>
        <input type="url" name="success_redirect" id="f_success_redirect"
          value="<%= location.success_redirect||'' %>"
          placeholder="https://... hoặc /menu/1">
        <small>Sau khi bấm “Mở Internet”, OpenNDS sẽ đưa khách vào trang này. Không để IP router (vd 192.168.x.x) — sẽ bị 404.</small>
      </div>
      <div class="field">
        <label>Link Zalo OA (dùng nếu chưa điền URL trên)</label>
        <input type="url" name="zalo_link" id="f_zalo_link" value="<%= location.zalo_link||'' %>" oninput="refresh()">
        <small>Fallback: Zalo → Menu (nếu bật) → trang chào portal.</small>
      </div>
      <div class="field">
        <label>Link đánh giá Google Business</label>
        <input type="url" name="google_review_url" id="f_google_review_url"
          value="<%= location.google_review_url||'' %>"
          placeholder="https://g.page/r/.../review">
        <small>Hiển thị nút ⭐ trên Menu và trang chào sau WiFi.</small>
      </div>
      <p style="font-size:12px;margin-top:10px">
        <a href="/admin/survey/<%= location.id %>" style="color:#7C3AED;font-weight:700">📋 Quản lý khảo sát Q&A →</a>
      </p>
    </div>

    <!-- Tab: Colors -->
    <div class="panel" id="panel-colors">
      <p class="section-title">Bảng màu</p>
      <% const colorFields = [
        {name:'accent_color', label:'Màu nhấn (nút, viền)', val:location.accent_color||'#B4452C'},
        {name:'bg_color',     label:'Màu nền trang',        val:location.bg_color||'#FFF6EC'},
        {name:'card_color',   label:'Màu nền thẻ / input',  val:location.card_color||'#FFFFFF'},
        {name:'text_color',   label:'Màu chữ chính',        val:location.text_color||'#241610'},
      ]; %>
      <% colorFields.forEach(f => { %>
      <div class="field">
        <label><%= f.label %></label>
        <div class="color-row">
          <div class="color-swatch" style="background:<%= f.val %>">
            <input type="color" name="<%= f.name %>" id="f_<%= f.name %>" value="<%= f.val %>"
              oninput="this.parentElement.style.background=this.value;syncHex(this);refresh()">
          </div>
          <span class="color-label"><%= f.label %></span>
          <input class="color-hex" type="text" value="<%= f.val %>" data-target="f_<%= f.name %>"
            oninput="syncFromHex(this)" maxlength="7">
        </div>
      </div>
      <% }); %>
    </div>

    <!-- Tab: Advanced -->
    <div class="panel" id="panel-adv">
      <p class="section-title">CSS tùy chỉnh</p>
      <div class="field">
        <textarea name="custom_css" id="f_custom_css" style="min-height:160px;font-size:11px" oninput="refresh()" placeholder="/* CSS thêm, ghi đè mọi style trên portal */&#10;body { font-family: 'Arial', sans-serif; }&#10;button { border-radius: 4px; }"><%= location.custom_css||'' %></textarea>
        <small>Chạy trong captive portal — không dùng Google Fonts hay CDN ngoài.</small>
      </div>
      <p class="section-title">Thông tin kỹ thuật</p>
      <div style="background:#f8fafc;border-radius:8px;padding:12px;font-size:12px;color:#475569;line-height:1.7">
        <b>Gateway name:</b> <%= location.gateway_name %><br>
        <b>FAS Key:</b> ••••••••<br>
        <a href="/preview/<%= location.id %>" target="_blank" style="color:#3B82F6;font-weight:600">
          🔗 Xem portal trên tab mới →</a>
      </div>
    </div>

    <!-- Hidden fields cho tất cả values -->
    <input type="hidden" name="faskey" value="<%= location.faskey %>">

  </form>
  </div><!-- /panels -->
</div><!-- /sidebar -->

<!-- ════════ PREVIEW ════════ -->
<div class="preview-panel">
  <div class="pv-head">
    <h3>Preview real-time</h3>
    <div class="device-btns">
      <button class="device-btn active" onclick="setDevice('mobile',this)">📱 Mobile</button>
      <button class="device-btn" onclick="setDevice('desktop',this)">🖥️ Desktop</button>
    </div>
  </div>
  <div class="pv-frame-wrap" id="frameWrap">
    <div class="phone-shell" id="phoneShell">
      <div class="phone-notch"></div>
      <div class="phone-screen">
        <iframe id="previewFrame" title="Portal Preview"></iframe>
      </div>
    </div>
    <iframe id="desktopFrame" class="desktop-frame" title="Desktop Preview" style="display:none"></iframe>
  </div>
</div>

</div><!-- /shell -->

<script>
/* ── Tab switching ── */
function switchTab(id, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-nav button').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-' + id).classList.add('active');
  btn.classList.add('active');
}

/* ── Device toggle ── */
let currentDevice = 'mobile';
function setDevice(mode, btn) {
  currentDevice = mode;
  document.querySelectorAll('.device-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const phone = document.getElementById('phoneShell');
  const desk  = document.getElementById('desktopFrame');
  if (mode === 'mobile') { phone.style.display=''; desk.style.display='none'; }
  else                   { phone.style.display='none'; desk.style.display=''; }
  refresh();
}

/* ── Templates ── */
const TEMPLATES = [
  { id:'classic',  name:'Cơm Tấm',    desc:'Ấm áp truyền thống', emoji:'🍚', bg:'#FFF6EC', accent:'#B4452C', card:'#FFFFFF', text:'#241610' },
  { id:'dark',     name:'Đêm Đô Thị', desc:'Hiện đại sang trọng', emoji:'🌃', bg:'#0f0f23', accent:'#7C3AED', card:'#1a1a35', text:'#e8e8f5' },
  { id:'fresh',    name:'Xanh Tươi',  desc:'Tự nhiên mát mẻ',    emoji:'🌿', bg:'#f0fff4', accent:'#276749', card:'#ffffff', text:'#1a4731' },
  { id:'ocean',    name:'Biển Xanh',  desc:'Trong sáng mát mẻ',  emoji:'🌊', bg:'#ebf8ff', accent:'#1d4ed8', card:'#ffffff', text:'#1e3a5f' },
  { id:'sunset',   name:'Hoàng Hôn',  desc:'Ấm nóng nổi bật',   emoji:'🌅', bg:'#fff5f5', accent:'#c2410c', card:'#fffaf0', text:'#7c2d12' },
  { id:'minimal',  name:'Tối Giản',   desc:'Sạch chuyên nghiệp', emoji:'⬜', bg:'#f8fafc', accent:'#1e293b', card:'#ffffff', text:'#0f172a' },
];

function buildTemplateGrid() {
  const grid = document.getElementById('tplGrid');
  const current = document.getElementById('f_template_id').value;
  grid.innerHTML = TEMPLATES.map(t => `
    <div class="tpl-card ${t.id===current?'selected':''}" onclick="applyTemplate('${t.id}')">
      <div class="tpl-preview" style="background:${t.bg}">
        <span style="font-size:24px">${t.emoji}</span>
        <div style="width:40px;height:28px;background:${t.card};border-radius:4px;margin-left:6px;border:1px solid rgba(0,0,0,.08)">
          <div style="height:4px;background:${t.accent};border-radius:2px;margin:6px 4px 4px"></div>
          <div style="height:3px;background:${t.accent};border-radius:2px;margin:0 4px;opacity:.4"></div>
        </div>
      </div>
      <div class="tpl-name">${t.name}</div>
      <div class="tpl-desc">${t.desc}</div>
    </div>`).join('');
}

function applyTemplate(id) {
  const t = TEMPLATES.find(x=>x.id===id);
  if (!t) return;
  document.getElementById('f_template_id').value = id;
  setColor('accent_color', t.accent);
  setColor('bg_color',     t.bg);
  setColor('card_color',   t.card);
  setColor('text_color',   t.text);
  buildTemplateGrid();
  refresh();
}

function setColor(name, val) {
  const inp = document.getElementById('f_'+name);
  if (!inp) return;
  inp.value = val;
  inp.parentElement.style.background = val;
  const hex = document.querySelector(`.color-hex[data-target="f_${name}"]`);
  if (hex) hex.value = val;
}

/* ── Color sync ── */
function syncHex(colorInput) {
  const hex = document.querySelector(`.color-hex[data-target="${colorInput.id}"]`);
  if (hex) hex.value = colorInput.value;
}
function syncFromHex(hexInput) {
  const v = hexInput.value.trim();
  if (/^#[0-9a-fA-F]{6}$/.test(v)) {
    const ci = document.getElementById(hexInput.dataset.target);
    if (ci) { ci.value = v; ci.parentElement.style.background = v; }
    refresh();
  }
}

/* ── Logo upload ── */
document.getElementById('logoFile').addEventListener('change', function() {
  if (!this.files[0]) return;
  if (this.files[0].size > 1024*1024) { alert('Ảnh quá lớn! Vui lòng dùng ảnh dưới 1MB.'); return; }
  const reader = new FileReader();
  reader.onload = e => { setLogo(e.target.result); };
  reader.readAsDataURL(this.files[0]);
});

const drop = document.getElementById('logoDrop');
drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('over'); });
drop.addEventListener('dragleave', () => drop.classList.remove('over'));
drop.addEventListener('drop', e => {
  e.preventDefault(); drop.classList.remove('over');
  const f = e.dataTransfer.files[0];
  if (f && f.type.startsWith('image/')) {
    const r = new FileReader(); r.onload = ev => setLogo(ev.target.result); r.readAsDataURL(f);
  }
});

function setLogo(dataUrl) {
  document.getElementById('f_logo_data').value = dataUrl;
  document.getElementById('logoPreviewImg').src = dataUrl;
  document.getElementById('logoDrop').style.display = 'none';
  document.getElementById('logoPreviewWrap').style.display = 'block';
  refresh();
}

function removeLogo() {
  document.getElementById('f_logo_data').value = '';
  document.getElementById('logoDrop').style.display = '';
  document.getElementById('logoPreviewWrap').style.display = 'none';
  refresh();
}

// Khởi tạo logo preview nếu đã có logo
(function(){
  const v = document.getElementById('f_logo_data').value;
  if (v) setLogo(v);
})();

/* ── show_name toggle ── */
document.getElementById('f_show_name').addEventListener('change', function() {
  const row = document.getElementById('requireNameRow');
  row.style.opacity = this.checked ? '1' : '.4';
  row.style.pointerEvents = this.checked ? '' : 'none';
});

/* ── Collect settings ── */
function getVal(id) {
  const el = document.getElementById(id);
  if (!el) return '';
  if (el.type==='checkbox') return el.checked ? '1' : '0';
  return el.value;
}

function collectSettings() {
  return {
    display_name: getVal('f_display_name'),
    headline:     getVal('f_headline'),
    promo_text:   getVal('f_promo_text'),
    btn_text:     getVal('f_btn_text'),
    accent_color: getVal('f_accent_color'),
    bg_color:     getVal('f_bg_color'),
    card_color:   getVal('f_card_color'),
    text_color:   getVal('f_text_color'),
    logo_data:    getVal('f_logo_data'),
    show_name:    getVal('f_show_name'),
    require_name: getVal('f_require_name'),
    custom_css:   getVal('f_custom_css'),
    zalo_link:    getVal('f_zalo_link'),
  };
}

/* ── Build portal HTML (mirror server template) ── */
function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function buildPortalHTML(s) {
  const accent = s.accent_color || '#B4452C';
  const bg     = s.bg_color     || '#F4F6FA';
  const card   = s.card_color   || '#FFFFFF';
  const ink    = s.text_color   || '#1A1F2E';
  const muted  = ink + '88';

  const logoHTML = s.logo_data
    ? `<img src="${s.logo_data}" alt="Logo" style="max-width:100%;max-height:100%;object-fit:contain;border-radius:8px">`
    : `<svg style="width:48px;height:48px" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" fill="${accent}" opacity=".15"/><path d="M12 28a12 12 0 0 1 24 0" stroke="${accent}" stroke-width="2.5" stroke-linecap="round"/><path d="M17 32a7 7 0 0 1 14 0" stroke="${accent}" stroke-width="2.5" stroke-linecap="round"/><circle cx="24" cy="36" r="2" fill="${accent}"/></svg>`;

  const promoHTML = s.promo_text
    ? `<p style="margin-top:20px;padding:14px 16px;font-size:13px;line-height:1.5;text-align:left;background:rgba(255,255,255,.14);border:1px solid rgba(255,255,255,.22);border-radius:12px">${esc(s.promo_text)}</p>` : '';

  const nameHTML = s.show_name === '1'
    ? `<div style="margin-bottom:16px"><label style="font-size:13px;font-weight:600;display:block;margin-bottom:6px">Họ tên</label>
       <input type="text" placeholder="VD: Nguyễn Văn A" style="width:100%;padding:14px 16px;font-size:16px;border:1.5px solid rgba(0,0,0,.1);border-radius:16px;box-sizing:border-box"></div>` : '';

  const btnLabel = esc(s.btn_text || 'Kết nối Internet');

  return `<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:-apple-system,"Segoe UI",Roboto,sans-serif;background:${bg};color:${ink};min-height:100vh;display:flex;flex-direction:column}
@media(min-width:720px){body{flex-direction:row}}
.brand{flex:0 0 42%;background:linear-gradient(145deg,${accent} 0%,color-mix(in srgb,${accent} 70%,#fff) 100%);color:#fff;padding:40px 32px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}
.brand h1{font-size:24px;font-weight:800;margin:12px 0 6px}
.brand p{font-size:15px;opacity:.9}
.logo{width:88px;height:88px;background:#fff;border-radius:20px;padding:10px;margin:0 auto;box-shadow:0 12px 40px rgba(0,0,0,.15);display:flex;align-items:center;justify-content:center}
.badge{display:inline-block;background:rgba(255,255,255,.2);padding:8px 16px;border-radius:999px;font-size:11px;font-weight:700;text-transform:uppercase;margin-bottom:20px}
.main{flex:1;padding:40px 32px;display:flex;align-items:center;justify-content:center}
.shell{max-width:380px;width:100%}
.shell h2{font-size:22px;font-weight:800;margin-bottom:6px}
.shell .sub{font-size:14px;color:${muted};margin-bottom:24px}
.input-wrap{display:flex;border:1.5px solid rgba(0,0,0,.1);border-radius:16px;overflow:hidden;margin-bottom:16px;background:${card}}
.prefix{padding:14px;background:rgba(0,0,0,.04);font-weight:600;font-size:14px;border-right:1px solid rgba(0,0,0,.08)}
.input-wrap input{flex:1;border:none;padding:14px 16px;font-size:16px;outline:none;background:transparent}
button{width:100%;padding:16px;font-size:16px;font-weight:800;color:#fff;background:${accent};border:none;border-radius:16px;cursor:pointer}
.note{margin-top:16px;font-size:11px;color:#888;line-height:1.5}
${s.custom_css || ''}
</style></head><body>
<aside class="brand">
  <span class="badge">Free WiFi</span>
  <div class="logo">${logoHTML}</div>
  <h1>${esc(s.display_name)}</h1>
  <p>${esc(s.headline||'WiFi Miễn Phí')}</p>
  ${promoHTML}
</aside>
<main class="main"><div class="shell">
  <p style="font-size:11px;font-weight:700;color:${accent};text-transform:uppercase;margin-bottom:6px">Bước 1 — Xác thực</p>
  <h2>Đăng nhập WiFi</h2>
  <p class="sub">Nhập số điện thoại để kết nối Internet.</p>
  <div class="input-wrap"><span class="prefix">+84</span><input type="tel" placeholder="9xx xxx xxx"></div>
  ${nameHTML}
  <button type="button">${btnLabel}</button>
  <p class="note">Bấm "${btnLabel}" nghĩa là bạn đồng ý cho ${esc(s.display_name)} lưu SĐT để gửi ưu đãi.</p>
</div></main>
</body></html>`;
}

/* ── Refresh preview ── */
let refreshTimer = null;
function refresh() {
  clearTimeout(refreshTimer);
  refreshTimer = setTimeout(() => {
    const html = buildPortalHTML(collectSettings());
    const mf = document.getElementById('previewFrame');
    const df = document.getElementById('desktopFrame');
    if (mf) mf.srcdoc = html;
    if (df) df.srcdoc = html;
  }, 80);
}

/* ── Init ── */
buildTemplateGrid();
refresh();

// Toast tự ẩn
const toast = document.getElementById('toast');
if (toast) setTimeout(() => toast.style.opacity='0', 2500);
</script>
</body>
</html>
